{
  "apps": [
    {
      "id": "slack",
      "name": "Slack",
      "platforms": ["macos"],
      "description": "Slack desktop app storage on macOS.",
      "user_access_paths": [
        "~/Library/Application Support/Slack",
        "~/Library/Logs/Slack"
      ],
      "warnings": [
        "Do not delete app data blindly unless you know which category is safe."
      ],
      "paths": [
        {
          "path": "~/Library/Application Support/Slack/Cache",
          "category": "cache",
          "description": "Electron cache files.",
          "accessible_path": "~/Library/Application Support/Slack",
          "safe_to_clean_hint": "Usually disposable cache, but verify Slack is closed before cleanup."
        },
        {
          "path": "~/Library/Logs/Slack",
          "category": "logs",
          "description": "Slack application logs.",
          "accessible_path": "~/Library/Logs/Slack",
          "safe_to_clean_hint": "Logs are often safe to remove if you do not need diagnostics."
        }
      ]
    },
    {
      "id": "notion",
      "name": "Notion",
      "platforms": ["macos"],
      "description": "Notion desktop app storage on macOS.",
      "paths": [
        {
          "path": "~/Library/Application Support/Notion/Cache",
          "category": "cache",
          "description": "Notion runtime cache.",
          "safe_to_clean_hint": "Cache is often rebuildable after restart."
        },
        {
          "path": "~/Library/Caches/notion.id",
          "category": "cache",
          "description": "Updater or app cache files."
        }
      ]
    }
  ]
}